#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
DEMO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"

if [[ -z "${REAL_OPENCODE:-}" ]]; then
  candidates=(
    "${DEMO_ROOT}/.tools/opencode/node_modules/.bin/opencode"
    "${HOME:-}/.opencode/bin/opencode"
    "${HOME:-}/.local/bin/opencode"
    "${HOME:-}/.npm-global/bin/opencode"
    "/usr/local/bin/opencode"
    "/usr/bin/opencode"
  )
  if command -v opencode >/dev/null 2>&1; then
    candidates+=("$(command -v opencode)")
  fi

  for candidate in "${candidates[@]}"; do
    if [[ -n "${candidate}" && -x "${candidate}" && "${candidate}" != "${SCRIPT_DIR}/opencode" ]]; then
      REAL_OPENCODE="${candidate}"
      break
    fi
  done
fi

if [[ -z "${REAL_OPENCODE:-}" ]]; then
  printf 'Could not find the real opencode binary.\n' >&2
  printf 'Run ./install.sh to install the local OpenCode CLI, or set REAL_OPENCODE=/path/to/opencode.\n' >&2
  exit 1
fi

export OPENCODE_CONFIG="${OPENCODE_CONFIG:-${DEMO_ROOT}/opencode/opencode.json}"
export OPENCODE_DISABLE_PROJECT_CONFIG="${OPENCODE_DISABLE_PROJECT_CONFIG:-true}"

if [[ "${1:-}" == "models" ]]; then
  echo "ollama/qwen3-coder:30b-48k-od"
  exit 0
fi

if [[ "${1:-}" == "run" ]]; then
  shift
  RUN_DIR="${OD_PROJECT_DIR:-$PWD}"
  exec "${REAL_OPENCODE}" run --dir "${RUN_DIR}" --dangerously-skip-permissions "$@"
fi

exec "${REAL_OPENCODE}" "$@"
